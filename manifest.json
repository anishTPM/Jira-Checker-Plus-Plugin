{
  "manifest_version": 3,
  "name": "Jira Checker Plus",
  "version": "3.1.0",
  "description": "Validates Jira issues and highlights missing or inconsistent information",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*.atlassian.net/*", "*://*/jira/*", "*://*/browse/*", "*://*/wiki/*", "*://confluence.tenerity.com/*"],
  "update_url": "https://raw.githubusercontent.com/anishTPM/Jira-Checker-Plus-Plugin/main/updates.xml",
  "options_page": "options.html",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/jira-28.png",
      "48": "icons/jira-56.png"
    },
    "default_title": "Jira Checker Plus"
  },
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/browse/*", "*://*/jira/browse/*", "*://*/browse/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.atlassian.net/projects/*/versions/*", "*://*/projects/*/versions/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*/secure/Tempo*", "*://*/plugins/servlet/ac/io.tempo.jira/*", "*://*.atlassian.net/plugins/servlet/ac/io.tempo.jira/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/jira-28.png",
    "48": "icons/jira-56.png",
    "128": "icons/jira-56.png"
  }
}
